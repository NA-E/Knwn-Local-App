# Railway Procfile — defines service processes
# Note: For multi-service setups on Railway, each service is a separate
# Railway service within the same project, each with its own root directory.
# This Procfile is for the main Next.js web service only.
#
# The MCP server (mcp-server/) should be deployed as a separate Railway
# service pointing to the mcp-server/ subdirectory with:
#   web: node dist/index.js

web: npm start
