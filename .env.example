# =============================================================================
# Known Local App — Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in the values.
# NEVER commit .env.local to version control.
# =============================================================================

# ---------------------------------------------------------------------------
# Supabase (required)
# ---------------------------------------------------------------------------

# Supabase project URL (e.g., https://xxxxxxxxxxxx.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=

# Supabase anonymous/public key (safe for client-side use)
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase service role key (server-side only — has full DB access, bypasses RLS)
# Used by: onboarding API route, auto-link/provision in layout, client portal actions
SUPABASE_SERVICE_ROLE_KEY=

# ---------------------------------------------------------------------------
# Client Onboarding Automation (optional — onboarding works without these
# but individual steps will fail)
# ---------------------------------------------------------------------------

# Slack Bot OAuth token (xoxb-...) — creates channels, invites users, posts welcome messages
SLACK_BOT_TOKEN=

# Dropbox API credentials — creates client folders in team Dropbox
DROPBOX_APP_KEY=
DROPBOX_APP_SECRET=
DROPBOX_REFRESH_TOKEN=

# Google service account credentials (JSON string) — creates Google Drive folders
# Generate from Google Cloud Console > IAM > Service Accounts > Keys > JSON
GOOGLE_SERVICE_ACCOUNT_JSON=

# Google Drive parent folder ID where client folders are created
GOOGLE_DRIVE_PARENT_FOLDER_ID=

# Comma-separated emails to invite to client Slack channels during onboarding
ONBOARD_INVITE_EMAILS=

# ---------------------------------------------------------------------------
# MCP Server (only needed if running mcp-server/ locally)
# These go in mcp-server/.env, NOT in .env.local
# ---------------------------------------------------------------------------
# SUPABASE_URL=           (same as NEXT_PUBLIC_SUPABASE_URL but without NEXT_PUBLIC_ prefix)
# SUPABASE_ANON_KEY=      (same as NEXT_PUBLIC_SUPABASE_ANON_KEY but without NEXT_PUBLIC_ prefix)
# KNOWNLOCAL_EMAIL=       (admin user email for MCP server authentication)
# KNOWNLOCAL_PASSWORD=    (admin user password)
# MCP_TRANSPORT=          ("http" for remote/Railway, "stdio" for local/Claude Desktop)
# PORT=                   (HTTP port for MCP server, default 3001)
